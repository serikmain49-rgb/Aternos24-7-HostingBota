# Параметры сервера
SERVER_IP=SMP-FRUTLINE.aternos.me
SERVER_PORT=29506
BOT_NAME=WanderingBot

# Поведение бота (для bot-advanced.js)
JUMP_INTERVAL=800              # Интервал прыжков в миллисекундах
CHANGE_DIR_TIME=3000           # Время между сменами направления
ENABLE_ROTATION=true           # Вращение головы (true/false)
AUTO_RECONNECT=true            # Автоматическое переподключение
RECONNECT_DELAY=5000           # Задержка перед переподключением в мс

# Для DebugBot (если добавишь логирование)
DEBUG=false
LOG_LEVEL=info
